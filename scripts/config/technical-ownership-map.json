{
  "version": 1,
  "areas": [
    {
      "id": "auth",
      "owner": "auth",
      "primaryMetric": "loginVisibleMs, authFeedbackMs",
      "gates": ["check:critical-coverage", "test:release-confidence"],
      "runbooks": ["docs/RUNBOOK_AUTH_ACCESS_INCIDENTS.md", "docs/RUNBOOK_OPERATIONAL_BUDGETS.md"]
    },
    {
      "id": "sync",
      "owner": "storage",
      "primaryMetric": "offline_to_online smoke, sync queue budgets",
      "gates": [
        "test:smoke:critical-runtime",
        "test:emulator:sync:ci",
        "check:flow-performance-budget"
      ],
      "runbooks": ["docs/RUNBOOK_SYNC_RESILIENCE.md", "docs/RUNBOOK_OPERATIONAL_BUDGETS.md"]
    },
    {
      "id": "repositories",
      "owner": "repositories",
      "primaryMetric": "critical repository coverage and emulator sync",
      "gates": ["check:quality", "test:emulator:sync:ci"],
      "runbooks": ["docs/RUNBOOK_SYNC_RESILIENCE.md"]
    },
    {
      "id": "clinical-documents",
      "owner": "clinical-documents",
      "primaryMetric": "clinicalDocumentsVisibleMs",
      "gates": ["check:critical-coverage", "test:smoke:critical-runtime", "test:e2e:critical:ci"],
      "runbooks": ["docs/RUNBOOK_OPERATIONAL_BUDGETS.md"]
    },
    {
      "id": "census",
      "owner": "census",
      "primaryMetric": "censoVisibleMs, censoRecordReadyMs",
      "gates": ["check:critical-coverage", "check:flow-performance-budget", "test:e2e:critical:ci"],
      "runbooks": ["docs/RUNBOOK_OPERATIONAL_BUDGETS.md", "docs/RUNBOOK_SUPPORT_OPERATIONS.md"]
    },
    {
      "id": "handoff",
      "owner": "handoff",
      "primaryMetric": "critical handoff coverage",
      "gates": ["check:critical-coverage", "test:ci:unit"],
      "runbooks": ["docs/CI_GATES_AND_FAILURE_RUNBOOKS.md"]
    },
    {
      "id": "backup",
      "owner": "backup",
      "primaryMetric": "backupFilesVisibleMs",
      "gates": ["check:flow-performance-budget", "test:e2e:critical:ci"],
      "runbooks": ["docs/RUNBOOK_OPERATIONAL_BUDGETS.md", "docs/RUNBOOK_SUPPORT_OPERATIONS.md"]
    }
  ]
}
